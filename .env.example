# Porta do servidor (precisa bater com o redirect URI cadastrado no Google Cloud Console)
PORT=8081

# Conexão com o Postgres (docker-compose expõe em localhost:5432)
DATABASE_URL=postgresql://postgres:password@localhost:5432/bootcamp-treinos-api

# Chave secreta do BetterAuth (gere uma string aleatória segura)
BETTER_AUTH_SECRET=

# URL pública da própria API (precisa bater com o redirect URI cadastrado no Google Cloud Console)
API_BASE_URL=http://localhost:8081

# Credenciais OAuth do Google (console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Chave da API do Gemini, usada nas rotas de IA (aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=

# Chave da OpenAI (opcional)
OPENAI_API_KEY=

# URL do frontend, usada para configurar CORS
WEB_APP_BASE_URL=http://localhost:3000

NODE_ENV=development
